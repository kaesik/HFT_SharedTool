<Window x:Class="HFT_SharedTool.LicenseAccountSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HFT Shared Tool"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        MaxWidth="700"
        MaxHeight="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource AccentColorBrush}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource AccentDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="MinWidth" Value="460" />
            <Setter Property="MinHeight" Value="200" />
            <Setter Property="MaxHeight" Value="480" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{DynamicResource CardBgBrush}"
                                BorderBrush="{DynamicResource BorderColorBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{DynamicResource SurfaceHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColorBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{DynamicResource ControlBgBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColorBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Rectangle Width="52" Height="28"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="/HFT_SharedTool;component/Assets/logo.png" Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Text="WYBÓR KONTA TEKLA"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource CloseButton}"
                        Content="&#xE8BB;"
                        Click="CloseButton_Click"
                        ToolTip="Zamknij" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="16,10,16,16">
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />

                <TextBlock Text="Wybierz konto, na którym pracujesz."
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,12" />

                <TextBlock Text="KONTA LICENCYJNE"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,0,0,6" />

                <ListBox x:Name="AccountsListBox"
                         DisplayMemberPath="DisplayText"
                         SelectedValuePath="LicenseId"
                         KeyboardNavigation.TabNavigation="Continue"
                         IsTextSearchEnabled="False"
                         Foreground="{DynamicResource TextPrimaryBrush}" />

                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,12,0,12" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ActionButton}"
                            Content="OK"
                            Click="Ok_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>