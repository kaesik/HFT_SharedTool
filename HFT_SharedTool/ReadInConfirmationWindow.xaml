<Window x:Class="HFT_SharedTool.ReadInConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HFT Shared Tool"
        Width="420"
        SizeToContent="Height"
        MinHeight="190"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
        <!-- Primary action — accent fill (matches ActionButton in LicenseAccountSelectionWindow) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource AccentColorBrush}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource AccentDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Neutral action — surface fill with border -->
        <Style x:Key="NeutralButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ControlBgBrush}"
                                BorderBrush="{DynamicResource BorderColorBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Title Bar (matches LicenseAccountSelectionWindow) ── -->
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Rectangle Width="32" Height="32"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="/HFT_SharedTool;component/Assets/logo.png"
                                        Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Text="POTWIERDZENIE READ IN"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource CloseButton}"
                        Content="&#xE8BB;"
                        Click="CloseButton_Click"
                        ToolTip="Zamknij" />
            </Grid>

            <!-- ── Content ── -->
            <StackPanel Grid.Row="1" Margin="16,10,16,16">
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />

                <TextBlock Text="Czy pobieranie się udało?"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,6" />

                <TextBlock Text="Jeżeli pobieranie dalej trwa — kliknij Tak po udanym pobieraniu."
                           TextWrapping="Wrap"
                           FontSize="11"
                           LineHeight="18"
                           Foreground="{DynamicResource TextSecondaryBrush}" />

                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,12,0,12" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource NeutralButton}"
                            Content="Nie"
                            Click="NoButton_Click" />
                    <Button Style="{StaticResource ActionButton}"
                            Content="Tak"
                            Margin="8,0,0,0"
                            Click="YesButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>