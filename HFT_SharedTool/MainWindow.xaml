<Window x:Class="HFT_SharedTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HFT Shared Tool"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="700"
        MinHeight="420"
        MaxWidth="1000"
        MaxHeight="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Window.Resources>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Rectangle Width="52" Height="28"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="/HFT_SharedTool;component/Assets/logo.png" Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Text="SHARED TOOL"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="RefreshButton"
                            Style="{StaticResource IconButton}"
                            Click="BtnRefresh_Click"
                            ToolTip="Odśwież"
                            Visibility="Collapsed">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   x:Name="RefreshIcon"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="RefreshIconRotate" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>

                    <Button x:Name="ThemeToggleButton"
                            Style="{StaticResource IconButton}"
                            Click="ThemeToggle_Click"
                            ToolTip="Przełącz motyw">
                        <TextBlock x:Name="ThemeToggleIcon"
                                   Text="&#xE793;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Button>

                    <Button Style="{StaticResource CloseButton}"
                            Content="&#xE8BB;"
                            Click="CloseButton_Click"
                            ToolTip="Zamknij" />
                </StackPanel>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="16,10,16,16">
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />

                <TextBlock Text="STATUS"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="ModelDrawingLabel"
                           Text="Status modelu"
                           FontSize="11"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />


                <Border BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource ControlBgBrush}">
                    <StackPanel>
                        <Grid Margin="12,8,12,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="115" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="2"
                                       Text="ZALOGOWANI"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,2" />
                        </Grid>

                        <ScrollViewer x:Name="LogScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MinHeight="260"
                                      MaxHeight="600"
                                      Padding="12,0,12,12">
                            <StackPanel x:Name="LogPanel"
                                        TextBlock.Foreground="{DynamicResource TextPrimaryBrush}" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>