<Window x:Class="HFT_SharedTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HFT Shared Tool"
        SizeToContent="WidthAndHeight"
        MinWidth="700"
        MinHeight="420"
        MaxWidth="1000"
        MaxHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        FontFamily="Segoe UI"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#D8DEE6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="RichTextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D8DEE6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsDocumentEnabled" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="MinWidth" Value="640"/>
            <Setter Property="MinHeight" Value="260"/>
            <Setter Property="MaxHeight" Value="650"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="HFT Shared Tool"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="ModelDrawingLabel"
                           Text="Status modelu"
                           FontSize="14"
                           Foreground="#4B5563"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Log operacji"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <RichTextBox x:Name="LogTextBox"
                             Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>