<Window x:Class="HFT_SharedTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HFT Shared Tool"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MinWidth="700"
        MinHeight="420"
        MaxWidth="1000"
        MaxHeight="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI">

    <Border Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Rectangle Width="52" Height="28"
                               Fill="{DynamicResource TextPrimaryBrush}"
                               RenderOptions.BitmapScalingMode="HighQuality">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="/HFT_SharedTool;component/Assets/logo.png" Stretch="Uniform" />
                        </Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Text="SHARED TOOL"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Content="&#xE793;"
                            Click="ThemeToggle_Click"
                            ToolTip="Przełącz motyw" />
                    <Button Style="{StaticResource CloseButton}"
                            Content="&#xE8BB;"
                            Click="CloseButton_Click"
                            ToolTip="Zamknij" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="16,10,16,16">
                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />

                <TextBlock Text="STATUS"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="ModelDrawingLabel"
                           Text="Status modelu"
                           FontSize="11"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <Border Height="1"
                        Background="{DynamicResource DividerColorBrush}"
                        Margin="0,0,0,12" />

                <TextBlock Text="LOG OPERACJI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,0,0,6" />

                <Border BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{DynamicResource ControlBgBrush}">
                    <ScrollViewer x:Name="LogScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MinHeight="260"
                                  MaxHeight="600"
                                  Padding="12">
                        <StackPanel x:Name="LogPanel"
                                    TextBlock.Foreground="{DynamicResource TextPrimaryBrush}" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>